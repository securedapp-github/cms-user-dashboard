# Server
PORT=3000
NODE_ENV=development

# Deployed CMS API host: https://cmsbe.securedapp.io (cmsbe, not cms-be)
#
# If the admin SPA is on another host (e.g. https://cms-app.securedapp.io), the SPA build
# MUST use that API URL as Axios/fetch base (e.g. VITE_API_URL=https://cmsbe.securedapp.io).
# Requests to the SPA origin for /api/... or /auth/... return 404 — only the API serves those routes.
# On THIS server, allow the SPA in CORS, exact origin, no trailing slash:
# CORS_ORIGIN=https://cms-app.securedapp.io

# --- Production (set on the host / platform) ---
# NODE_ENV=production
# CORS_ORIGIN=https://your-spa.example.com,https://www.your-spa.example.com
# (Exact browser origins: scheme + host + port. No trailing slash. Required for credentialed API calls from the SPA.)
# Behind nginx/ALB you may need: app.set('trust proxy', 1) — see README / docs if rate limits or IPs look wrong.

# Logging (Winston): LOG_LEVEL=error|warn|info|debug; LOG_DIR=logs for file output
# LOG_LEVEL=info
# LOG_DIR=logs

# Rate limits (per window): RATE_LIMIT_WINDOW_MS (default 900000 = 15 min)
# RATE_LIMIT_MAX_GENERAL=200
# RATE_LIMIT_MAX_AUTH=10
# RATE_LIMIT_MAX_PUBLIC=60

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
# Create "OAuth 2.0 Client ID" → Application type: Web application
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# JWT (use a long random string, e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# End-user portal (/user): optional separate secret; defaults to JWT_SECRET
# USER_PORTAL_JWT_SECRET=
# USER_PORTAL_JWT_EXPIRES_IN=7d
# Days ahead to treat consent as "expiring_soon" in portal filters/summary
# USER_PORTAL_EXPIRING_SOON_DAYS=7

# Dev only: set SKIP_DB_SYNC=true to skip auto-sync when using `npm run dev` (faster restarts)
# SKIP_DB_SYNC=true
#
# Production: default data catalog rows are upserted on `npm start` (idempotent). To disable:
# SKIP_CATALOG_SEED=true

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=securedapp_cms
DB_USER=root
DB_PASSWORD=your_mysql_password
# DB_LOGGING=true   # set to see raw SQL in terminal (dev only)
#
# TLS (production uses SSL by default). If you see "self-signed certificate in certificate chain":
# - Prefer: DB_SSL_CA=/path/to/ca-bundle.pem (e.g. AWS RDS combined CA file)
# - Or for internal/demo DB only: DB_SSL_REJECT_UNAUTHORIZED=false
# Dev against TLS: DB_USE_SSL=true
# DB_SSL_CA=
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_USE_SSL=true

# Redis (off by default; set REDIS_ENABLED=true to use webhook queue)
# REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SMTP (optional; used for redirect-consent OTP emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password_or_app_password
# EMAIL_USER=your_smtp_username     # alias supported
# EMAIL_PASS=your_smtp_password      # alias supported
# SMTP_FROM_EMAIL=no-reply@yourdomain.com
# SMTP_FROM_NAME=SecureDApp CMS

# Optional: CORS (comma-separated origins). If unset, dev defaults allow common localhost ports.
# Production: include your SPA origin exactly (scheme + host + port), e.g. https://app.example.com
# CORS_ORIGIN=https://app.example.com,http://localhost:5173
